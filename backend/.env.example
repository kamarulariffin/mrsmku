# MongoDB (optional fallback for hybrid mode)
MONGO_URL=mongodb://localhost:27017
DB_NAME=mrsm_portal

# Database engine mode:
# - mongo: legacy MongoDB mode
# - hybrid: core modules use PostgreSQL, non-core remain MongoDB
# - postgres: semua koleksi menggunakan PostgreSQL (disyorkan)
DB_ENGINE=postgres

# PostgreSQL (for hybrid/postgres mode)
DATABASE_URL=postgresql+psycopg://kamarulariffin@localhost:5432/mrsm_portal

# Financial dashboard performance tuning
# TTL cache response (seconds)
FINANCIAL_DASHBOARD_CACHE_TTL_SECONDS=45
# Max docs fetched per heavy financial query
FINANCIAL_DASHBOARD_MAX_FETCH_DOCS=200000
# Use PostgreSQL materialized cache table for cross-restart cache
FINANCIAL_DASHBOARD_PERSISTENT_CACHE_ENABLED=1
# Enable cache invalidation telemetry counters
FINANCIAL_DASHBOARD_INVALIDATION_METRICS_ENABLED=1
# Rolling window for per-scope invalidation hit count (seconds)
FINANCIAL_DASHBOARD_INVALIDATION_WINDOW_SECONDS=3600
# Minimum interval to emit invalidation metrics log summary (seconds)
FINANCIAL_DASHBOARD_INVALIDATION_LOG_INTERVAL_SECONDS=600

# JWT (ubah untuk production)
JWT_SECRET=your-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Optional: LLM
# EMERGENT_LLM_KEY=

# E-mel — pilih satu atau lebih (prioriti: SES → Resend → SMTP → mod dev)
# Resend (https://resend.com):
# RESEND_API_KEY=re_xxxxx
# SENDER_EMAIL=onboarding@resend.dev

# AWS SES (production):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-southeast-1
# SENDER_EMAIL=noreply@domain.com

# SMTP — localhost (Mailtrap, MailHog, Gmail, dll.)
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_USER=your_mailtrap_user
# SMTP_PASSWORD=your_mailtrap_password
# SMTP_USE_TLS=true
# SENDER_EMAIL=test@contoh.com
