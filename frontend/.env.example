# Backend API (ubah jika backend guna port lain)
REACT_APP_BACKEND_URL=http://localhost:8000

# Peta live bas (Google Maps) – wajib untuk halaman Peta Live Bas
# Dapatkan API key di: https://console.cloud.google.com/apis/credentials
